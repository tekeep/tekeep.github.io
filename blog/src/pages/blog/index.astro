---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostListLayout from '../../components/PostListLayout.astro';
import { getCollection } from 'astro:content';
import { sortPosts } from '../../utils/posts';

const allPosts = await getCollection('blog');
const now = new Date();
const posts = sortPosts(allPosts.filter(p => new Date(p.data.publishedAt) <= now));
---
<Layout title="ブログ" description="TeKeep の最新記事一覧">
  <Header />
  <PostListLayout posts={posts} heading="最新記事" icon="fa-solid fa-newspaper" />
  <Footer />
</Layout>
