---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostListLayout from '../../components/PostListLayout.astro';
import { getCollection } from 'astro:content';
import { sortPosts } from '../../utils/posts';
import { isPublished } from '../../utils/date';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const publishedPosts = posts.filter(p => isPublished(p.data.publishedAt));
  const categories = [...new Set(publishedPosts.map(p => p.data.category || '未分類'))];
  return categories.map(category => ({
    params: { category },
    props: { posts: sortPosts(publishedPosts.filter(p => (p.data.category || '未分類') === category)) },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
---
<Layout title={`${category} | TeKeep! ブログ`} description={`${category}カテゴリーの記事一覧です。`}>
  <Header />
  <PostListLayout posts={posts} heading={`「${category}」の記事一覧`} icon="fa-solid fa-folder-open" />
  <Footer />
</Layout>
