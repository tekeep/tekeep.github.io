---
import Layout from '../../../components/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostListLayout from '../../../components/PostListLayout.astro';
import { getCollection } from 'astro:content';
import { sortPosts } from '../../../utils/posts';
import { isPublished } from '../../../utils/date';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const publishedPosts = posts.filter(p => isPublished(p.data.publishedAt));

  const archiveMap = new Map();
  publishedPosts.forEach(post => {
    const d = new Date(post.data.publishedAt);
    if (isNaN(d.getTime())) return;
    const year = d.getFullYear().toString();
    const month = (d.getMonth() + 1).toString();
    const key = `${year}-${month}`;
    if (!archiveMap.has(key)) {
      archiveMap.set(key, { year, month, posts: [] });
    }
    archiveMap.get(key).posts.push(post);
  });

  return Array.from(archiveMap.values()).map(({ year, month, posts }) => ({
    params: { year, month },
    props: { posts: sortPosts(posts) },
  }));
}

const { year, month } = Astro.params;
const { posts } = Astro.props;
---
<Layout title={`${year}年${month}月 | TeKeep! ブログ`} description={`${year}年${month}月の記事一覧です。`}>
  <Header />
  <PostListLayout posts={posts} heading={`${year}年${month}月の記事一覧`} icon="fa-solid fa-box-archive" />
  <Footer />
</Layout>
