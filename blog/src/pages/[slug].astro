---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import PostMeta from '../components/PostMeta.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id.split('/').pop() } }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find(p => p.id.split('/').pop() === slug);
if (!post) {
  throw new Error('Post not found');
}
const { title, seoTitle, socialTitle, description, publishedAt, updatedAt, image } = post.data;
const { Content } = await render(post);
---
<Layout title={title} seoTitle={seoTitle} socialTitle={socialTitle} description={description} image={image}>
  <Header />
  <main class="container blog-layout">
  <article class="post">
    <h1 class="post-title">{title}</h1>
    <PostMeta publishedAt={publishedAt} updatedAt={updatedAt} />
    <Content />
    <div class="cta-banner" style="margin-top: 16px; text-align: center;">
      <a href="https://tekeep.com/">
        <img src="/blog/images/cta-banner.webp" alt="TeKeep! の CTA バナー" style="max-width: 100%; height: auto;" />
      </a>
    </div>
    

  </article>
  <Sidebar />
</main>
  <footer><Footer /></footer>
</Layout>
